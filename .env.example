# Environment Configuration Template
# Copy this file to .env and fill in the actual values

# MongoDB Atlas Connection (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Session Secret (Required - Change to a strong random string)
SESSION_SECRET=your-very-strong-session-secret-here

# Google Maps API Keys (Required for geocoding)
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Provider Sign-up Security Password
# Shared password gate for provider self-signup. /api/auth/verify-
# provider-signup-password and /api/auth/register both check against this
# value, so rotation is a one-line env var change.
PROVIDER_SIGNUP_PASSWORD=set-a-strong-shared-password-here

# Environment Mode
NODE_ENV=development

# API URL Configuration
REACT_APP_API_URL=http://localhost:5000

# SMS Gateway (cloud mode via api.sms-gate.app)
# See docs/SMS_GATEWAY_SETUP.md for full setup. Endpoint URL is hardcoded
# in server/services/smsService.js — no SMS_GATEWAY_URL env var is needed.
SMS_GATEWAY_USERNAME=your_cloud_account_username
SMS_GATEWAY_PASSWORD=your_cloud_account_password
# Required if your sms-gate.app account has more than one paired device.
# SMS_GATEWAY_DEVICE_ID=your_device_id
# Optional: which SIM to send from (1-3); defaults to SIM 1.
# SMS_GATEWAY_SIM_NUMBER=1

# Email Configuration (Required for password reset)
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
# EMAIL_FROM=noreply@yourdomain.com  # Optional: defaults to onboarding@resend.dev

# Cloudinary (Logo upload — provider white-label branding)
# Free tier covers our usage by orders of magnitude. Both vars are public
# (exposed in the client bundle) — that's expected for unsigned uploads.
# In Cloudinary dashboard: Settings → Upload → Upload presets → create an
# unsigned preset with strict limits (max ~2 MB, png/jpg/svg/webp only,
# folder e.g. avayble/logos/, auto-quality, max-dim ~600px).
REACT_APP_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
REACT_APP_CLOUDINARY_LOGO_UPLOAD_PRESET=your-unsigned-upload-preset-name

# Google Calendar Integration (OAuth2)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google-calendar/oauth/callback
GOOGLE_WEBHOOK_SECRET=your-random-webhook-secret

# Stripe Connect Payment Integration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret  # Optional: for production webhook verification

# Optional: Error Tracking (if needed)
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/your-project-id

# Heroku Deployment Note:
# Set these environment variables in your Heroku dashboard:
# heroku config:set MONGODB_URI=your-mongodb-uri
# heroku config:set SESSION_SECRET=your-secret
# heroku config:set GOOGLE_MAPS_API_KEY=your-key
# heroku config:set NODE_ENV=production
# heroku config:set PROVIDER_SIGNUP_PASSWORD=your-shared-password

# Email Password Recovery
# RESEND_API_KEY=re_your_api_key_here
