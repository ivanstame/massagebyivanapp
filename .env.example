# Environment Configuration Template
# Copy this file to .env and fill in the actual values

# MongoDB Atlas Connection (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Session Secret (Required - Change to a strong random string)
SESSION_SECRET=your-very-strong-session-secret-here

# Google Maps API Keys (Required for geocoding)
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Provider Sign-up Security Password
PROVIDER_SIGNUP_PASSWORD=B@ckstreetsback0222

# Environment Mode
NODE_ENV=development

# API URL Configuration
REACT_APP_API_URL=http://localhost:5000

# Android SMS Gateway Configuration (via Tailscale VPN)
# Replace 100.x.y.z with your actual Tailscale IP address of the Android device
SMS_GATEWAY_URL=http://100.x.y.z:8080
SMS_GATEWAY_USERNAME=your_gateway_username
SMS_GATEWAY_PASSWORD=your_gateway_password
# Optional: Specify a particular device ID if you have multiple devices
# SMS_GATEWAY_DEVICE_ID=your_device_id
# Optional: Specify which SIM card to use (1-3)
# SMS_GATEWAY_SIM_NUMBER=1

# Email Configuration (Required for password reset)
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
# EMAIL_FROM=noreply@yourdomain.com  # Optional: defaults to onboarding@resend.dev

# Stripe Connect Payment Integration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret  # Optional: for production webhook verification

# Optional: Error Tracking (if needed)
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/your-project-id

# Heroku Deployment Note:
# Set these environment variables in your Heroku dashboard:
# heroku config:set MONGODB_URI=your-mongodb-uri
# heroku config:set SESSION_SECRET=your-secret
# heroku config:set GOOGLE_MAPS_API_KEY=your-key
# heroku config:set NODE_ENV=production
# heroku config:set PROVIDER_SIGNUP_PASSWORD=B@ckstreetsback0222