{
  "name": "my-massage-app",
  "version": "1.0.0",
  "description": "My Massage Booking App",
  "main": "server/server.js",
  "scripts": {
    "server": "dotenv -e .env --override -- nodemon server/server.js",
    "server:local": "dotenv -e .env.development --override -- nodemon server/server.js",
    "server:cloud": "dotenv -e .env --override -- nodemon server/server.js",
    "client": "react-app-rewired start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:local": "concurrently \"npm run server:local\" \"npm run client\"",
    "build": "react-app-rewired build",
    "heroku-postbuild": "npm run build",
    "test": "jest",
    "eject": "react-scripts eject"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.2",
    "@react-google-maps/api": "^2.19.3",
    "axios": "^1.8.1",
    "axios-cookiejar-support": "^6.0.4",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "cypress": "^13.15.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "full-icu": "^1.5.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.454.0",
    "luxon": "^3.5.0",
    "moment-timezone": "^0.5.46",
    "mongoose": "^5.12.3",
    "node-cache": "^5.1.2",
    "opossum": "^8.1.4",
    "p-limit": "^3.1.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "react": "^18.3.1",
    "react-calendar": "^5.0.0",
    "react-datepicker": "^7.3.0",
    "react-dom": "^18.3.1",
    "react-feather": "^2.0.10",
    "react-google-autocomplete": "^2.7.3",
    "react-router-dom": "^6.26.1",
    "react-transition-group": "^4.4.5",
    "recharts": "^2.15.0",
    "request": "^2.88.2",
    "resend": "^6.9.4",
